    {
      "name": "Predict - Invalid Payload",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Test: Verify validation error handling",
              "pm.test('Invalid payload returns 422 error', function() {",
              "    pm.response.to.have.status(422);",
              "});",
              "",
              "pm.test('Error response has proper format', function() {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('detail');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
